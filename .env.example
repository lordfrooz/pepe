# Yerel gelistirme ayarlari. Bu dosya git'e gitmez (.gitignore).
# Railway'de bunlari servisin Variables sekmesine girin.

# Kampanya (pinned) tweet ID'si — x.com/robinpepega/status/<BU_SAYI>
# Bos birakilirsa like/repost/comment gorevleri profili acar.
PINNED_TWEET_ID=

# X kullanici adi (@ olmadan)
X_HANDLE=robinpepega

# CSV export anahtari: /api/export?key=<ADMIN_KEY>
ADMIN_KEY=

# Postgres baglantisi. Yerelde bos birakilirsa gecici bellek deposu kullanilir.
# DATABASE_URL=

# Sosyal medya onizlemelerindeki (OG/Twitter) mutlak adres.
# Bos birakilirsa istekten otomatik algilanir; custom domain'de sabitlemek isterseniz doldurun.
# SITE_URL=https://robinpepe.xyz

# PORT=3000
